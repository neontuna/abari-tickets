IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SSL=1
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=your-app-password
IMAP_MAILBOX=Repairs
INBOX_LIMIT=10

# Production pipeline
IMAP_PROCESSED_MAILBOX=Repairs/Printed
IMAP_SKIPPED_MAILBOX=Repairs/Skipped
POLL_INTERVAL_SECONDS=180
BODY_MIN_CHARS=5
BODY_MAX_CHARS=1500
DB_PATH=/app/data/repairs.sqlite3
TZ=America/New_York
