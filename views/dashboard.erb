<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="refresh" content="60">
  <title>abari-repairs</title>
  <style>
    body { font: 14px/1.4 system-ui, sans-serif; max-width: 1200px; margin: 2em auto; padding: 0 1em; color: #222; }
    h1 { margin-bottom: 0; }
    .sub { color: #666; margin-top: 0.25em; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1em; margin: 1.5em 0; }
    .card { border: 1px solid #ddd; border-radius: 6px; padding: 1em; }
    .card h2 { margin: 0 0 0.5em; font-size: 1em; color: #555; text-transform: uppercase; letter-spacing: 0.05em; }
    .big { font-size: 2em; font-weight: 600; }
    .ok { color: #2a7a2a; }
    .bad { color: #b22; }
    table { border-collapse: collapse; width: 100%; margin-top: 0.5em; }
    th, td { text-align: left; padding: 0.4em 0.6em; border-bottom: 1px solid #eee; vertical-align: top; }
    td.when { white-space: nowrap; }
    th { background: #fafafa; font-weight: 600; }
    .reason { color: #b22; }
    .body { color: #555; font-style: italic; }
    .deferred-row td { background: #fff8e1; }
    .action-printed  { color: #2a7a2a; font-weight: 600; }
    .action-skipped  { color: #b22; font-weight: 600; }
    .action-deferred { color: #a06400; font-weight: 600; }
    code { background: #f3f3f3; padding: 0.1em 0.3em; border-radius: 3px; }
  </style>
</head>
<body>
  <h1>abari-repairs</h1>
  <p class="sub">Polling every <%= @poll_interval %>s &middot; up since <%= @booted_at.strftime("%Y-%m-%d %-I:%M:%S %p") %></p>

  <div class="grid">
    <div class="card">
      <h2>Printed today</h2>
      <div class="big"><%= @today_count %></div>
    </div>
    <div class="card">
      <h2>Printer</h2>
      <div class="big <%= @printer_status.ok? ? "ok" : "bad" %>">
        <%= @printer_status.summary %>
      </div>
      <div class="sub">
        paper: <%= @printer_status.paper %>
        &middot; cover: <%= @printer_status.cover_open ? "open" : "closed" %>
      </div>
    </div>
  </div>

  <div class="grid">
    <div class="card">
      <h2>Last printed</h2>
      <% if @last_printed %>
        <div><strong><%= @last_printed["subject"] || "(no subject)" %></strong></div>
        <div><%= @last_printed["sender"] %></div>
        <div class="sub"><%= fmt_time(@last_printed["occurred_at"]) %></div>
        <% if @last_printed["body_excerpt"] && !@last_printed["body_excerpt"].empty? %>
          <div class="body">"<%= @last_printed["body_excerpt"] %>"</div>
        <% end %>
      <% else %>
        <div class="sub">none yet</div>
      <% end %>
    </div>
    <div class="card">
      <h2>Last skipped</h2>
      <% if @last_skipped %>
        <div><strong><%= @last_skipped["subject"] || "(no subject)" %></strong></div>
        <div><%= @last_skipped["sender"] %></div>
        <div class="sub"><%= fmt_time(@last_skipped["occurred_at"]) %></div>
        <div class="reason"><%= @last_skipped["reason"] %></div>
      <% else %>
        <div class="sub">none yet</div>
      <% end %>
    </div>
  </div>

  <h2>Recent events</h2>
  <% if @recent.empty? %>
    <p class="sub">No events recorded yet. Sit tight; the next poll fires within <%= @poll_interval %>s.</p>
  <% else %>
    <table>
      <thead>
        <tr><th>When</th><th>Action</th><th>From</th><th>Subject</th><th>Reason / excerpt</th></tr>
      </thead>
      <tbody>
        <% @recent.each do |row| %>
          <tr class="<%= row["action"] == "deferred" ? "deferred-row" : "" %>">
            <td class="when"><%= fmt_time(row["occurred_at"]) %></td>
            <td><span class="action-<%= row["action"] %>"><%= row["action"] %></span></td>
            <td><%= row["sender"] %></td>
            <td><%= row["subject"] %></td>
            <td>
              <% if row["action"] == "printed" %>
                <span class="body"><%= row["body_excerpt"] %></span>
              <% else %>
                <span class="reason"><%= row["reason"] %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</body>
</html>
