#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"

begin
  require "dotenv"
  Dotenv.load
rescue LoadError
  # dotenv is dev-only; in non-dev environments rely on real ENV
end

require "net/imap"
require "mail"

REQUIRED_VARS = %w[IMAP_HOST IMAP_USERNAME IMAP_PASSWORD].freeze

def abort_with(message)
  warn "error: #{message}"
  exit 1
end

missing = REQUIRED_VARS.reject { |k| ENV[k] && !ENV[k].empty? }
abort_with("missing required env var(s): #{missing.join(', ')}") unless missing.empty?

host     = ENV.fetch("IMAP_HOST")
port     = Integer(ENV.fetch("IMAP_PORT", "993"))
ssl      = ENV["IMAP_SSL"]&.to_i == 1
username = ENV.fetch("IMAP_USERNAME")
password = ENV.fetch("IMAP_PASSWORD")
mailbox  = ENV.fetch("IMAP_MAILBOX", "INBOX")
limit    = Integer(ENV.fetch("INBOX_LIMIT", "10"))

imap = nil
begin
  imap = Net::IMAP.new(host, port: port, ssl: ssl)

  begin
    imap.login(username, password)
  rescue Net::IMAP::NoResponseError => e
    abort_with("IMAP login failed for #{username}@#{host}: #{e.message}")
  end

  imap.examine(mailbox)

  seqnos = imap.search(["ALL"])
  recent = seqnos.last(limit)

  if recent.empty?
    puts "(no messages in #{mailbox})"
  else
    puts "Last #{recent.size} message(s) in #{mailbox} on #{host}:"
    recent.each do |seqno|
      raw = imap.fetch(seqno, "RFC822").first.attr["RFC822"]
      mail = Mail.read_from_string(raw)
      date = mail.date ? mail.date.iso8601 : "(no date)"
      from = Array(mail.from).first || "(unknown sender)"
      subject = mail.subject || "(no subject)"
      puts "#{date}  #{from}  #{subject}"
    end
  end
ensure
  if imap
    begin
      imap.logout if imap.respond_to?(:logout) && !imap.disconnected?
    rescue StandardError
      # logout best-effort
    end
    begin
      imap.disconnect unless imap.disconnected?
    rescue StandardError
      # disconnect best-effort
    end
  end
end
